exports[`Security surface snapshot > Policies RLS 1`] = `
[
  {
    "name": "audit_log_select_admin",
    "operation": "select",
    "table": "audit_log",
    "using": "public.is_admin()",
    "withCheck": null,
  },
  {
    "name": "event_participants_delete",
    "operation": "delete",
    "table": "event_participants",
    "using": "auth.uid() = user_id",
    "withCheck": null,
  },
  {
    "name": "event_participants_insert",
    "operation": "insert",
    "table": "event_participants",
    "using": null,
    "withCheck": "auth.uid() = user_id and not public.is_banned(auth.uid()) and public.event_has_room(event_id)",
  },
  {
    "name": "event_participants_select",
    "operation": "select",
    "table": "event_participants",
    "using": "true",
    "withCheck": null,
  },
  {
    "name": "events_delete_admin",
    "operation": "delete",
    "table": "events",
    "using": "public.is_admin()",
    "withCheck": null,
  },
  {
    "name": "events_insert_admin",
    "operation": "insert",
    "table": "events",
    "using": null,
    "withCheck": "public.is_admin()",
  },
