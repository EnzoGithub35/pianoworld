# Pourquoi ce flag :
# - eslint v9 + @eslint/js v10 + plugins (react-hooks v7, jsx-a11y, etc.)
#   ont des peer ranges incompatibles côté metadata, mais runtime OK.
# - Sans ce flag : npm install / npm ci échoue (ERESOLVE) sur les hôtes
#   qui n'acceptent pas de flags ligne de commande (notamment Vercel).
# - Avec ce flag : on accepte les peer deps désalignées et on remet ça
#   à plat plus tard quand les plugins ESLint auront convergé.
#
# À retirer dès que la chaîne ESLint v9 sera stabilisée.
legacy-peer-deps=true
