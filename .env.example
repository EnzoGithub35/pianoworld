VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
# Optionnel (laisse vide pour désactiver Sentry en dev)
VITE_SENTRY_DSN=
# Clé publique VAPID pour les notifications Web Push (générée via `npx web-push generate-vapid-keys`)
# Laisser vide en local désactive l'opt-in push, sans casser le reste.
VITE_VAPID_PUBLIC_KEY=
